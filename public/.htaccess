Options -Indexes
RewriteEngine On

# Si le fichier exact existe, le servir directement
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Si c'est un dossier avec index.html, le servir
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)/$ $1/index.html [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f  
RewriteRule ^(.+[^/])$ $1/index.html [L]

# Fallback vers home uniquement si rien d'autre ne matche
RewriteRule ^ /index.html [L]
